        venue.bookDate(date)
    END CONSTRUCTOR

    METHOD addTier(tier)
        Add tier TO tiers
    END METHOD

    METHOD sellTicket(seatNumber, tier)
        IF seatNumber IN soldSeats THEN
            DISPLAY "Seat already sold"
        ELSE IF tier.getRemainingSeats() <= 0 THEN
            DISPLAY "Tier full"
        ELSE
            Add seatNumber TO soldSeats
            CREATE Ticket
        END IF
    END METHOD

    METHOD getRemainingTickets()
        total = 0

        FOR EACH t IN tiers
            total = total + t.getRemainingSeats()
        END FOR

        RETURN total
    END METHOD
END CLASS


