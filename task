    CONSTRUCTOR Subject(id, name, syllabus, schedule)
        SET subjectID TO id
        SET subjectName TO name
        SET this.syllabus TO syllabus
        SET this.schedule TO schedule
    END CONSTRUCTOR
END CLASS


CLASS Assessment
    ATTRIBUTES
        assessmentID : Integer
        assessmentName : String
        weight : Real

    CONSTRUCTOR Assessment(id, name, weight)
        SET assessmentID TO id
        SET assessmentName TO name
        SET this.weight TO weight
    END CONSTRUCTOR
END CLASS


CLASS Grade
    ATTRIBUTES
        score : Real
        assessment : Assessment

    CONSTRUCTOR Grade(score, assessment)
        SET this.score TO score
        SET this.assessment TO assessment
    END CONSTRUCTOR
END CLASS


CLASS Student
    ATTRIBUTES
        studentID : Integer
        studentName : String
        personalRecord : String
        grades : List of Grade
        classSchedule : String

    CONSTRUCTOR Student(id, name, record)
        SET studentID TO id
        SET studentName TO name
        SET personalRecord TO record
        SET grades TO Empty List
    END CONSTRUCTOR

    METHOD addGrade(grade)
        Add grade TO grades
    END METHOD

    METHOD calculateAverage()
        totalWeighted = 0
        totalWeight = 0

        FOR EACH grade IN grades
            totalWeighted = totalWeighted + (grade.score * grade.assessment.weight)
            totalWeight = totalWeight + grade.assessment.weight
        END FOR

        IF totalWeight = 0 THEN
            RETURN 0
        END IF

        RETURN totalWeighted / totalWeight
    END METHOD
END CLASS


CLASS SchoolClass
    ATTRIBUTES
        classID : Integer
        className : String
        maxClassSize : Integer
        schedule : String
        teacher : Teacher
        subject : Subject
        students : List of Student

    CONSTRUCTOR SchoolClass(id, name, maxSize, schedule, teacher, subject)
        SET classID TO id
        SET className TO name
        SET this.maxClassSize TO maxSize
        SET this.schedule TO schedule
        SET this.teacher TO teacher
        SET this.subject TO subject
        SET students TO Empty List
    END CONSTRUCTOR

    METHOD enrollStudent(student)
        IF students.size >= maxClassSize THEN
            DISPLAY "Class Full"
        ELSE IF student.classSchedule = schedule THEN
            DISPLAY "Schedule Conflict"
        ELSE
            Add student TO students
            SET student.classSchedule TO schedule
        END IF
    END METHOD
END CLASS


