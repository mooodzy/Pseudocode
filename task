task 278: Veterinary Clinic

BEGIN

CLASS Owner
    ATTRIBUTES
        ownerID : Integer
        name : String
        phoneNumber : String
        pets : List of Pet

    CONSTRUCTOR Owner(id, name, phone)
        SET ownerID TO id
        SET this.name TO name
        SET phoneNumber TO phone
        SET pets TO Empty List
    END CONSTRUCTOR

    METHOD addPet(pet)
        Add pet TO pets
    END METHOD
END CLASS


CLASS Species
    ATTRIBUTES
        speciesName : String
        careRequirements : String

    CONSTRUCTOR Species(name, care)
        SET speciesName TO name
        SET careRequirements TO care
    END CONSTRUCTOR
END CLASS


CLASS Pet
    ATTRIBUTES
        petID : Integer
        name : String
        dateOfBirth : Date
        species : Species
        medicalHistory : List of Examination

    CONSTRUCTOR Pet(id, name, dob, species)
        SET petID TO id
        SET this.name TO name
        SET dateOfBirth TO dob
        SET this.species TO species
        SET medicalHistory TO Empty List
    END CONSTRUCTOR

    METHOD getAge()
        RETURN CurrentDate - dateOfBirth
    END METHOD

    METHOD addExamination(exam)
        Add exam TO medicalHistory
    END METHOD
END CLASS


CLASS Examination
    ATTRIBUTES
        examID : Integer
        diagnosis : String
        vitalSigns : String
        urgent : Boolean
        treatments : List of Treatment

    CONSTRUCTOR Examination(id, diagnosis, vitalSigns)
        SET examID TO id
        SET this.diagnosis TO diagnosis
        SET this.vitalSigns TO vitalSigns
        SET urgent TO False
        SET treatments TO Empty List
    END CONSTRUCTOR

    METHOD checkUrgency()
        IF vitalSigns are outside safe range THEN
            SET urgent TO True
        END IF
    END METHOD

    METHOD addTreatment(treatment)
        Add treatment TO treatments
    END METHOD
END CLASS


CLASS Treatment
    ATTRIBUTES
        treatmentID : Integer
        description : String
        cost : Double

    CONSTRUCTOR Treatment(id, desc, cost)
        SET treatmentID TO id
        SET description TO desc
        SET this.cost TO cost
    END CONSTRUCTOR
END CLASS


CLASS Visit
    ATTRIBUTES
        visitID : Integer
        owner : Owner
        pet : Pet
        examination : Examination

    CONSTRUCTOR Visit(id, owner, pet, exam)
        SET visitID TO id
        SET this.owner TO owner
        SET this.pet TO pet
        SET examination TO exam
    END CONSTRUCTOR

    METHOD getVisitTotal()
        RETURN Sum of treatment.cost
    END METHOD
END CLASS


START
BEGIN

CREATE OBJECT owner1 OF Owner
SET owner1.ownerID TO 101
SET owner1.name TO "Ali Ahmed"
SET owner1.phoneNumber TO "91234567"

CREATE OBJECT species1 OF Species
SET species1.speciesName TO "Dog"
SET species1.careRequirements TO "Regular Vaccination"

CREATE OBJECT pet1 OF Pet
SET pet1.petID TO 201
SET pet1.name TO "Max"
SET pet1.dateOfBirth TO "15/05/2022"
SET pet1.species TO species1

owner1.addPet(pet1)

CREATE OBJECT exam1 OF Examination
SET exam1.examID TO 301
SET exam1.diagnosis TO "Fever"
SET exam1.vitalSigns TO "High Temperature"

exam1.checkUrgency()

CREATE OBJECT treatment1 OF Treatment
SET treatment1.treatmentID TO 401
SET treatment1.description TO "Antibiotics"
SET treatment1.cost TO 15.00

exam1.addTreatment(treatment1)

CREATE OBJECT visit1 OF Visit
SET visit1.visitID TO 501
SET visit1.owner TO owner1
SET visit1.pet TO pet1
SET visit1.examination TO exam1

DISPLAY pet1.getAge()
DISPLAY visit1.getVisitTotal()

END
STOP
END PROGRAM





