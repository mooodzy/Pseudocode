Task 279: Movie Theater
CLASS Film
    ATTRIBUTES
        filmID : Integer
        title : String
        genre : String
        duration : Integer
    CONSTRUCTOR Film(id, title, genre, duration)
        filmID to id
        SET this.title to title
        SET this.genre to genre
        SET this.duration to duration
    END CONSTRUCTOR
END CLASS

CLASS Screen
    ATTRIBUTES
        screenID : Integer
        screenName : String
        capacity : Integer
        seatingLayout : String
    CONSTRUCTOR Screen(id, name, capacity, layout)
        screenID to id
        screenName to name
        SET this.capacity to capacity
        SET seatingLayout to layout
    END CONSTRUCTOR
END CLASS

CLASS Showtime
    ATTRIBUTES
        showtimeID : Integer
        startTime : DateTime
        endTime : DateTime
        film : Film
        screen : Screen
        tickets : List of Ticket
    CONSTRUCTOR Showtime(id, start, end, film, screen)
        showtimeID to id
        startTime to start
        endTime to end
        SET this.film to film
        SET this.screen to screen
        tickets to Empty List
    END CONSTRUCTOR
    METHOD addTicket(ticket)
        Add ticket TO tickets
    END METHOD
    METHOD getAvailableSeats()
        RETURN screen.capacity - tickets.size
    END METHOD
END CLASS

CLASS Ticket
    ATTRIBUTES
        ticketID : Integer
        customerName : String
        seatNumber : String
        showtime : Showtime
    CONSTRUCTOR Ticket(id, customer, seat, showtime)
        ticketID  id
        customerName to customer
        seatNumber to seat
        SET this.showtime ← showtime
    END CONSTRUCTOR
    METHOD reserveSeat()
        Display "Seat Reserved"
    END METHOD
END CLASS

