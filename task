CLASS Student
    ATTRIBUTES
        studentID : Integer
        studentName : String
        personalRecord : String
        grades : List of Grade
        classSchedule : String

    CONSTRUCTOR Student(id, name, record)
        SET studentID TO id
        SET studentName TO name
        SET personalRecord TO record
        SET grades TO Empty List
    END CONSTRUCTOR

    METHOD addGrade(grade)
        Add grade TO grades
    END METHOD

    METHOD calculateAverage()
        totalWeighted = 0
        totalWeight = 0

        FOR EACH grade IN grades
            totalWeighted = totalWeighted + (grade.score * grade.assessment.weight)
            totalWeight = totalWeight + grade.assessment.weight
        END FOR

        IF totalWeight = 0 THEN
            RETURN 0
        END IF

        RETURN totalWeighted / totalWeight
    END METHOD
END CLASS


