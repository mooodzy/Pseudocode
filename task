BEGIN

CLASS Owner
    ATTRIBUTES
        ownerID : Integer
        name : String
        phoneNumber : String
        pets : List of Pet

    CONSTRUCTOR Owner(id, name, phone)
        SET ownerID TO id
        SET this.name TO name
        SET phoneNumber TO phone
        SET pets TO Empty List
    END CONSTRUCTOR

    METHOD addPet(pet)
        Add pet TO pets
    END METHOD
END CLASS


CLASS Species
    ATTRIBUTES
        speciesName : String
        careRequirements : String

    CONSTRUCTOR Species(name, care)
        SET speciesName TO name
        SET careRequirements TO care
    END CONSTRUCTOR
END CLASS


CLASS Pet
    ATTRIBUTES
        petID : Integer
        name : String
        dateOfBirth : Date
        species : Species
        medicalHistory : List of Examination

    CONSTRUCTOR Pet(id, name, dob, species)
        SET petID TO id
        SET this.name TO name
        SET dateOfBirth TO dob
        SET this.species TO species
        SET medicalHistory TO Empty List
    END CONSTRUCTOR

    METHOD getAge()
        RETURN CurrentDate - dateOfBirth
    END METHOD

    METHOD addExamination(exam)
        Add exam TO medicalHistory
    END METHOD
END CLASS


CLASS Examination
    ATTRIBUTES
        examID : Integer
        diagnosis : String
        vitalSigns : String
        urgent : Boolean
        treatments : List of Treatment

    CONSTRUCTOR Examination(id, diagnosis, vitalSigns)
        SET examID TO id
        SET this.diagnosis TO diagnosis
        SET this.vitalSigns TO vitalSigns
        SET urgent TO False
        SET treatments TO Empty List
    END CONSTRUCTOR

    METHOD checkUrgency()
        IF vitalSigns are outside safe range THEN
            SET urgent TO True
        END IF
    END METHOD

    METHOD addTreatment(treatment)
        Add treatment TO treatments
    END METHOD
END CLASS


CLASS Treatment
    ATTRIBUTES
        treatmentID : Integer
        description : String
        cost : Double

    CONSTRUCTOR Treatment(id, desc, cost)
        SET treatmentID TO id
        SET description TO desc
        SET this.cost TO cost
    END CONSTRUCTOR
END CLASS


CLASS Visit
    ATTRIBUTES
        visitID : Integer
        owner : Owner
        pet : Pet
        examination : Examination

    CONSTRUCTOR Visit(id, owner, pet, exam)
        SET visitID TO id
        SET this.owner TO owner
        SET this.pet TO pet
        SET examination TO exam
    END CONSTRUCTOR

    METHOD getVisitTotal()
        RETURN Sum of treatment.cost
    END METHOD
END CLASS


