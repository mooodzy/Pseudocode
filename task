        stockMovements : List of StockMovement

    CONSTRUCTOR Product(id, name, category, vendor)
        SET productID TO id
        SET productName TO name
        SET this.category TO category
        SET this.vendor TO vendor
        SET bins TO Empty List
        SET stockMovements TO Empty List
    END CONSTRUCTOR

    METHOD addBin(bin)
        Add bin TO bins
    END METHOD

    METHOD addStockMovement(movement)
        IF movement.movementType = "OUT" AND
           movement.quantity > getTotalStock() THEN
            Display "Insufficient Stock"
        ELSE
            Add movement TO stockMovements
        END IF
    END METHOD

    METHOD getTotalStock()
        RETURN Sum of quantity in bins
    END METHOD

END CLASS


