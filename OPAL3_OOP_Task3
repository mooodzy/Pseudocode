    END METHOD

   METHOD sellTicket(seatNumber, tier)

    IF seatNumber IN soldSeats THEN
        DISPLAY "Seat already sold"

    ELSE IF tier.getRemainingSeats() <= 0 THEN
        DISPLAY "Tier full"

    ELSE
        ADD seatNumber TO soldSeats

        CREATE OBJECT ticket1 OF Ticket(1, seatNumber, tier)

        DISPLAY "Ticket Sold"
    END IF

    END METHOD

  METHOD getRemainingTickets()

    SET total TO 0

    FOR EACH t IN tiers
        SET total TO total + t.getRemainingSeats()
    END FOR

    RETURN total

END METHOD
END CLASS


