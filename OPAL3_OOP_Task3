CLASS Concert
    ATTRIBUTES
        PRIVATE concertID : Integer
        PRIVATE concertDate : String
        PRIVATE artist : Artist
        PRIVATE venue : Venue
        PRIVATE tiers : List of TicketTier
        PRIVATE soldSeats : List of String

    CONSTRUCTOR Concert(id, date, artist, venue)
        SET concertID TO id
        SET concertDate TO date
        SET this.artist TO artist
        SET this.venue TO venue
        SET tiers TO Empty List
        SET soldSeats TO Empty List

        venue.bookDate(date)
