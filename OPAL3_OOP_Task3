CLASS Developer
    ATTRIBUTES
        PRIVATE developerID : Integer
        PRIVATE developerName : String
        PRIVATE capacity : Integer
        PRIVATE assignedTasks : List of Task

    CONSTRUCTOR Developer(id, name, capacity)
        SET developerID TO id
        SET developerName TO name
        SET this.capacity TO capacity
        SET assignedTasks TO Empty List
    END CONSTRUCTOR

    METHOD canAssign()
        RETURN assignedTasks.size < capacity
    END METHOD

    METHOD assignTask(task)
        IF canAssign() THEN
            Add task TO assignedTasks
        ELSE
            DISPLAY "Capacity Reached"
        END IF
    END METHOD
END CLASS


CLASS Task
    ATTRIBUTES
        PRIVATE taskID : Integer
        PRIVATE taskName : String
        PRIVATE status : String   // Backlog → InProgress → Testing → Done
        PRIVATE developer : Developer

    CONSTRUCTOR Task(id, name)
        SET taskID TO id
        SET taskName TO name
        SET status TO "Backlog"
    END CONSTRUCTOR

    METHOD assignDeveloper(dev)
        IF dev.canAssign() THEN
            SET developer TO dev
            dev.assignTask(this)
        ELSE
            DISPLAY "Developer overloaded"
        END IF
    END METHOD

    METHOD moveToNextStage()
        IF status = "Backlog" THEN
            SET status TO "InProgress"
        ELSE IF status = "InProgress" THEN
            SET status TO "Testing"
        ELSE IF status = "Testing" THEN
            SET status TO "Done"
        END IF
    END METHOD

    METHOD markComplete()
        IF status = "Done" THEN
            DISPLAY "Task Completed"
        ELSE
            DISPLAY "Cannot complete task yet"
        END IF
    END METHOD
END CLASS


CLASS Backlog
    ATTRIBUTES
        tasks : List of Task

    CONSTRUCTOR Backlog()
        SET tasks TO Empty List
    END CONSTRUCTOR

    METHOD addTask(task)
        Add task TO tasks
    END METHOD

    METHOD getNextTask()
        RETURN first task in tasks
    END METHOD
END CLASS


CLASS Sprint
    ATTRIBUTES
        PRIVATE sprintID : Integer
        PRIVATE tasks : List of Task
        PRIVATE backlog : Backlog

    CONSTRUCTOR Sprint(id, backlog)
        SET sprintID TO id
        SET this.backlog TO backlog
        SET tasks TO Empty List
    END CONSTRUCTOR

   METHOD pullTask()
    IF backlog.tasks.size = 0 THEN
        DISPLAY "No tasks in backlog"
    ELSE
        task = backlog.getNextTask()
        Add task TO tasks
    END IF
   END METHOD

   METHOD calculateProgress()

    SET doneCount TO 0

    IF tasks.size = 0 THEN
        RETURN 0
    END IF

    REPEAT FROM i = 0 TO tasks.size - 1
        IF tasks[i].status = "Done" THEN
            SET doneCount TO doneCount + 1
        END IF
    END REPEAT

    RETURN (doneCount / tasks.size) * 100
    END METHOD

END CLASS


