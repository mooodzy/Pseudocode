    CONSTRUCTOR Venue(id, name, seating)
        SET venueID TO id
        SET venueName TO name
        SET seatingChart TO seating
        SET bookedDates TO Empty List
    END CONSTRUCTOR

    METHOD isAvailable(date)
        IF date IN bookedDates THEN
            RETURN False
        ELSE
            RETURN True
        END IF
    END METHOD

    METHOD bookDate(date)
        Add date TO bookedDates
    END METHOD
END CLASS


CLASS TicketTier
    ATTRIBUTES
        PRIVATE tierName : String
        PRIVATE price : Double
        PRIVATE totalSeats : Integer
        PRIVATE soldSeats : Integer

    CONSTRUCTOR TicketTier(name, price, seats)
        SET tierName TO name
        SET this.price TO price
        SET totalSeats TO seats
        SET soldSeats TO 0
    END CONSTRUCTOR

    METHOD getRemainingSeats()
        RETURN totalSeats - soldSeats
    END METHOD
END CLASS


CLASS Ticket
    ATTRIBUTES
        PRIVATE ticketID : Integer
        PRIVATE seatNumber : String
        PRIVATE price : Double
        PRIVATE tier : TicketTier

    CONSTRUCTOR Ticket(id, seat, tier)
        SET ticketID TO id
        SET seatNumber TO seat
